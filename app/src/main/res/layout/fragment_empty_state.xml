<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_empty_state.xml
    ────────────────────────
    Reusable empty state layout for screens with no data
    Used when:
    • No messages in inbox
    • No reports in admin panel
    • No search results
    • No notifications
    
    Features:
    • Large icon (64dp)
    • Title text
    • Description text
    • Call-to-action button (optional)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/bg_page">

    <!-- Empty state icon (64dp) -->
    <ImageView
        android:id="@+id/iv_empty_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_chat_bubble"
        android:scaleType="centerInside"
        android:contentDescription="Empty state"
        app:tint="@color/border" />

    <!-- Title text -->
    <TextView
        android:id="@+id/tv_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="No Messages Yet"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        tools:text="No Messages Yet" />

    <!-- Description text -->
    <TextView
        android:id="@+id/tv_empty_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Start a conversation or wait for responses to your reports"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        tools:text="Start a conversation or wait for responses" />

    <!-- CTA Button (optional, gone by default) -->
    <Button
        android:id="@+id/btn_empty_action"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Create New Post"
        android:visibility="gone"
        style="@style/MuniPulse.Button.Primary"
        tools:visibility="visible" />

</LinearLayout>
