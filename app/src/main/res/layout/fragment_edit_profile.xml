<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_edit_profile.xml
    ────────────────────────
    Edit Profile Screen — User can update their profile information
    ┌──────────────────────────────────┐
    │  Toolbar: "Edit Profile"  ✕      │
    │─────────────────────────────────│
    │  [NestedScrollView]              │
    │    Avatar picker + change button │
    │    Name input                    │
    │    Bio input                     │
    │    Location input                │
    │    Profession input              │
    │    Website input                 │
    │    Save button                   │
    └──────────────────────────────────┘
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/mp_blue"
        android:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:background="@color/mp_blue"
            app:title="Edit Profile"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_close"
            app:navigationIconTint="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Avatar Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <!-- Avatar circle with overlay -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center">

                    <TextView
                        android:id="@+id/tv_edit_avatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_profile_avatar"
                        android:gravity="center"
                        android:textColor="@color/mp_blue"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        tools:text="RK" />

                    <!-- Camera overlay icon -->
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_send_button"
                        android:src="@drawable/ic_edit"
                        android:scaleType="center"
                        android:padding="8dp"
                        android:contentDescription="Change avatar"
                        app:tint="@android:color/white" />

                </FrameLayout>

                <!-- Change photo button -->
                <Button
                    android:id="@+id/btn_change_avatar"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="Change Photo"
                    android:textSize="12sp"
                    style="@style/MuniPulse.Button.Outline"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

            <!-- ── Name Input ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_edit_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Full Name"
                style="@style/MuniPulse.TextInput"
                app:counterEnabled="true"
                app:counterMaxLength="50">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_edit_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="50"
                    android:inputType="text"
                    android:textSize="14sp"
                    tools:text="Rahul Kulkarni" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Bio Input ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_edit_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Bio"
                style="@style/MuniPulse.TextInput"
                app:counterEnabled="true"
                app:counterMaxLength="150">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_edit_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLength="150"
                    android:minLines="3"
                    android:maxLines="4"
                    android:inputType="textMultiLine|textCapSentences"
                    android:textSize="13sp"
                    tools:text="Passionate about civic improvements and community service" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Location Input ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_edit_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Location"
                style="@style/MuniPulse.TextInput"
                app:startIconDrawable="@drawable/ic_location"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_edit_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="14sp"
                    tools:text="Kothrud, Pune" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Profession Input ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_edit_profession"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Profession"
                style="@style/MuniPulse.TextInput">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_edit_profession"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="14sp"
                    tools:text="Software Engineer" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Website Input ── -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_edit_website"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="Website (optional)"
                style="@style/MuniPulse.TextInput">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_edit_website"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textSize="14sp"
                    tools:text="https://example.com" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Privacy Settings Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="184dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Privacy &amp; Visibility"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Profile visibility toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Public Profile"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_public_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <!-- Show reports toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Show My Reports"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_show_reports"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Action Buttons ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"

                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btn_save_profile"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Save Changes"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    style="@style/MuniPulse.Button.Primary" />

                <Button
                    android:id="@+id/btn_cancel_edit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textSize="14sp"
                    style="@style/MuniPulse.Button.Outline" />

            </LinearLayout>

            <!-- ── Danger Zone ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="@color/mp_red_light"
                app:cardElevation="0dp"
                app:strokeColor="@color/mp_red"
                app:strokeWidth="1dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Danger Zone"
                        android:textColor="@color/mp_red"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:id="@+id/btn_logout"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:text="🚪 Logout"
                        android:textColor="@color/mp_red"
                        android:textSize="12sp"
                        style="@style/MuniPulse.Button.Red"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btn_delete_account"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:text="🗑️ Delete Account"
                        android:textColor="@color/mp_red"
                        android:textSize="12sp"
                        style="@style/MuniPulse.Button.Red" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
