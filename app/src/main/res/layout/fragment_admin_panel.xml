<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_admin_panel.xml
    ────────────────────────
    Screen 4 — Government Admin Panel (visible only to role=ADMIN/GOV)
    ┌──────────────────────────────────┐
    │  Toolbar: "PMC Admin Panel"  🔔  │
    │  Tabs: Reports | Active | Done   │
    │  Stats header: Pending|Active|✅ │
    │  RecyclerView → item_report_admin│
    └──────────────────────────────────┘

    Role check in Kotlin:
      if (user.role == Role.ADMIN) showAdminPanel()
      else redirectToFeed()

    RecyclerView adapter: AdminReportAdapter.kt
    Buttons in item_report_admin.xml trigger:
      - WorkBegins  → update status + notify citizen + auto post "work started" on feed
      - NotFeasible → update status + notify citizen + leave post (no delete)
      - Message     → open chat with the reporting citizen
      - Delete      → delete post after work is completed/resolved
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/mp_blue"
        android:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_admin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/mp_blue">

            <!-- Logged-in admin info -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logged in as Admin"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tv_admin_ward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="PMC Admin Panel — Ward 12" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_admin_notifications"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_icon_button_round"
                android:src="@drawable/ic_notifications"
                app:tint="@android:color/white"
                android:contentDescription="Notifications" />

        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Status filter tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_admin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/bg_card"
            style="@style/MuniPulse.TabLayout"
            app:tabGravity="fill"
            app:tabMode="fixed">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📥 Reports" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔧 Active" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Done" />

        </com.google.android.material.tabs.TabLayout>

        <!-- ── Stats overview header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tv_ward_overview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overview — Pune Ward 12"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- 3-column stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Pending stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:layout_marginEnd="5dp">

                    <TextView
                        android:id="@+id/tv_stat_pending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/mp_orange"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="14" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- In Progress stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:layout_marginEnd="5dp"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:id="@+id/tv_stat_active"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/mp_blue"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="7" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="In Progress"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Resolved stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:id="@+id/tv_stat_resolved_admin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/mp_green"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="53" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resolved"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Report list -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_admin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_admin_reports"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="6dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_report_admin" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
