<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_post.xml
    ──────────────────
    RecyclerView item — one issue post card (citizen or official).
    Used in FeedAdapter.kt / FeedPostViewHolder.kt

    Visibility rules (set in ViewHolder):
    • iv_post_image    → VISIBLE if post has photo, GONE otherwise
    • cv_admin_reply   → VISIBLE if adminReply != null, GONE otherwise
    • chip_status      → always visible; tint based on PostStatus enum
    • badge_role       → text = "Citizen" | "Official" | "Admin"
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/MuniPulse.Card"
    android:focusable="true"
    android:clickable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header: Avatar + Name + Badge + Time ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Avatar circle -->
            <TextView
                android:id="@+id/tv_avatar"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_avatar_user"
                android:gravity="center"
                android:textColor="@color/mp_blue"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="RK" />

            <!-- Name + meta column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <!-- Name + role badge row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Rahul Kulkarni" />

                    <!-- Role badge: Citizen / Official / Admin -->
                    <TextView
                        android:id="@+id/badge_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_badge_citizen"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:textColor="@color/mp_blue"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:textStyle="bold"
                        tools:text="Citizen" />

                </LinearLayout>

                <!-- Location · time -->
                <TextView
                    android:id="@+id/tv_post_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    tools:text="Kothrud · 2 hrs ago" />

            </LinearLayout>

            <!-- Overflow menu button -->
            <ImageButton
                android:id="@+id/btn_post_menu"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Post options"
                android:src="@drawable/ic_more_vert"
                app:tint="@color/text_secondary" />

        </LinearLayout>

        <!-- ── Post image (optional) ── -->
        <ImageView
            android:id="@+id/iv_post_image"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:scaleType="centerCrop"
            android:contentDescription="Issue photo"
            android:background="@color/bg_page"
            android:visibility="gone"
            tools:visibility="visible"
            tools:src="@tools:sample/backgrounds/scenic" />

        <!-- ── Body: Title + Description + Status chip ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tv_post_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Massive pothole on Paud Road near Signal No. 4" />

            <TextView
                android:id="@+id/tv_post_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                android:maxLines="3"
                android:ellipsize="end"
                tools:text="This pothole has been here for 3 weeks and 2 bikes have already fallen. Urgent action needed!" />

            <!-- Status chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginTop="8dp"
                android:textSize="11sp"
                android:textStyle="bold"
                app:chipCornerRadius="24dp"
                app:chipBackgroundColor="@color/mp_yellow_light"
                app:chipStrokeWidth="0dp"
                app:rippleColor="@android:color/transparent"
                android:clickable="false"
                android:focusable="false"
                tools:text="⏳ Pending Review" />

        </LinearLayout>

        <!-- ── Official Admin Reply card (shown when gov responds) ── -->
        <LinearLayout
            android:id="@+id/cv_admin_reply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_admin_reply"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tv_admin_reply_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Official Response"
                android:textColor="@color/mp_green"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tv_admin_reply_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/mp_green"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                tools:text="Work order raised. Repair team scheduled for 22 Apr. Thank you for reporting." />

        </LinearLayout>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:background="@color/border" />

        <!-- ── Action buttons: Like · Comment · Share · Flag ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- Like -->
            <LinearLayout
                android:id="@+id/btn_like"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"

                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_like_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_heart_outline"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Like" />

                <TextView
                    android:id="@+id/tv_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    tools:text="248" />

            </LinearLayout>

            <!-- Comment -->
            <LinearLayout
                android:id="@+id/btn_comment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"

                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_comment"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Comment" />

                <TextView
                    android:id="@+id/tv_comment_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    tools:text="34" />

            </LinearLayout>

            <!-- Share -->
            <LinearLayout
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"

                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_share"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Share" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Flag / Report -->
            <LinearLayout
                android:id="@+id/btn_flag"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"

                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_flag"
                    app:tint="@color/mp_red"
                    android:contentDescription="Report post" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Report"
                    android:textColor="@color/mp_red"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
