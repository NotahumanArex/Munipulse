<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- Logo + Brand -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1560BD">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_launcher_foreground"
                    app:tint="#FFFFFF" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="MuniPulse"
                android:textColor="#0F172A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />
        </LinearLayout>

        <!-- Login Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Card Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back"
                    android:textColor="#0F172A"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.01"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign in to your community portal"
                    android:textColor="#94A3B8"
                    android:textSize="14sp"
                    android:layout_marginBottom="28dp" />

                <!-- Email Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email address"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <!-- Email Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="you@example.com"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"

                    app:boxBackgroundColor="#F8FAFC"
                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#CBD5E1"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="#94A3B8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:inputType="textEmailAddress"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="6dp" />

                <!-- Password Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_password"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="••••••••"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"

                    app:boxBackgroundColor="#F8FAFC"
                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#CBD5E1"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#94A3B8"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#94A3B8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:inputType="textPassword"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Remember Me + Forgot Password -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <CheckBox
                        android:id="@+id/cb_remember"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="Remember me"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:buttonTint="#1560BD" />

                    <TextView
                        android:id="@+id/tv_forgot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Forgot password?"
                        android:textColor="#1560BD"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="24dp"
                    android:text="Log In"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.01"
                    app:backgroundTint="#1560BD"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"
                    app:rippleColor="#1050A0" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E2E8F0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="or continue with"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E2E8F0" />
                </LinearLayout>

                <!-- Social Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_google"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Google"
                        android:textAllCaps="false"
                        android:textColor="#0F172A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_google"
                        app:iconTint="@null"
                        app:iconSize="18dp"
                        app:iconPadding="6dp"
                        app:cornerRadius="10dp"
                        app:strokeColor="#E2E8F0"
                        app:strokeWidth="1.5dp"
                        app:rippleColor="#F1F5F9" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_github"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="GitHub"
                        android:textAllCaps="false"
                        android:textColor="#0F172A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_github"
                        app:iconTint="#0F172A"
                        app:iconSize="18dp"
                        app:iconPadding="6dp"
                        app:cornerRadius="10dp"
                        app:strokeColor="#E2E8F0"
                        app:strokeWidth="1.5dp"
                        app:rippleColor="#F1F5F9" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sign Up Link -->
        <TextView
            android:id="@+id/tv_go_signup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Don't have an account? Sign Up"
            android:textColor="#64748B"
            android:textSize="14sp" />

        <!-- Admin Login -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_lock"
                app:tint="#94A3B8"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btn_admin_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADMIN LOGIN"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>