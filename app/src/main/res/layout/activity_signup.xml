<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="40dp">

        <!-- ───── Header ───── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <!-- App icon badge -->
            <androidx.cardview.widget.CardView
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1560BD">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_launcher_foreground"
                    app:tint="#FFFFFF" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="MuniPulse"
                android:textColor="#0F172A"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Join your community today"
                android:textColor="#64748B"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ───── Signup Card ───── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="28dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal info"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:layout_marginBottom="12dp" />

                <!-- First Name + Last Name Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_first_name"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:hint="First name"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"

                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="#94A3B8"
                        app:boxBackgroundColor="#FAFAFA">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_first_name"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:inputType="textPersonName|textCapWords"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_last_name"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:hint="Last name"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"

                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="#94A3B8"
                        app:boxBackgroundColor="#FAFAFA">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_last_name"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:inputType="textPersonName|textCapWords"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Email Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Email address"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"

                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#94A3B8"
                    app:boxBackgroundColor="#FAFAFA"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="#CBD5E1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:inputType="textEmailAddress"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Phone Number (Optional) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_phone"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Phone number"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"

                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#94A3B8"
                    app:boxBackgroundColor="#FAFAFA"
                    app:startIconDrawable="@drawable/ic_phone"
                    app:startIconTint="#CBD5E1"
                    app:suffixText="Optional"
                    app:suffixTextColor="#CBD5E1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_phone"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:inputType="phone"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Divider with label -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="Security"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#F1F5F9" />
                </LinearLayout>

                <!-- Password Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_password"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"

                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#94A3B8"
                    app:boxBackgroundColor="#FAFAFA"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#CBD5E1"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#CBD5E1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:inputType="textPassword"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Strength Indicator -->
                <LinearLayout
                    android:id="@+id/strength_bar_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="4"
                        android:layout_marginBottom="6dp">

                        <View
                            android:id="@+id/strength_seg_1"
                            android:layout_width="0dp"
                            android:layout_height="3dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:background="#E2E8F0"
                            android:backgroundTint="#E2E8F0" />

                        <View
                            android:id="@+id/strength_seg_2"
                            android:layout_width="0dp"
                            android:layout_height="3dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:background="#E2E8F0" />

                        <View
                            android:id="@+id/strength_seg_3"
                            android:layout_width="0dp"
                            android:layout_height="3dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:background="#E2E8F0" />

                        <View
                            android:id="@+id/strength_seg_4"
                            android:layout_width="0dp"
                            android:layout_height="3dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:background="#E2E8F0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_strength_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Use 8+ chars, a number and symbol"
                            android:textColor="#B0BEC5"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_strength_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Confirm Password Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_confirm_password"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Confirm password"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"

                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#94A3B8"
                    app:boxBackgroundColor="#FAFAFA"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="#CBD5E1"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#CBD5E1">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:inputType="textPassword"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Terms & Privacy -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_terms_row"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <CheckBox
                        android:id="@+id/cb_terms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#1560BD"
                        android:scaleX="0.9"
                        android:scaleY="0.9" />

                    <TextView
                        android:id="@+id/tv_terms"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="I agree to the Terms of Service and Privacy Policy"
                        android:textColor="#475569"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

                <!-- Create Account Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_signup"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:text="Create Account"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.01"
                    app:backgroundTint="#1560BD"
                    app:cornerRadius="14dp"
                    app:elevation="0dp"
                    app:rippleColor="#0F4A99" />

                <!-- OR Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#F1F5F9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="or sign up with"
                        android:textColor="#CBD5E1"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#F1F5F9" />
                </LinearLayout>

                <!-- Social Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_google"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Google"
                        android:textAllCaps="false"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        app:icon="@drawable/ic_google"
                        app:iconTint="@null"
                        app:iconSize="18dp"
                        app:iconPadding="6dp"
                        app:cornerRadius="12dp"
                        app:strokeColor="#E2E8F0"
                        app:strokeWidth="1.5dp"
                        app:backgroundTint="#FAFAFA" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_github"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="GitHub"
                        android:textAllCaps="false"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        app:icon="@drawable/ic_github"
                        app:iconTint="#334155"
                        app:iconSize="18dp"
                        app:iconPadding="6dp"
                        app:cornerRadius="12dp"
                        app:strokeColor="#E2E8F0"
                        app:strokeWidth="1.5dp"
                        app:backgroundTint="#FAFAFA" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ───── Footer ───── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account?"
                android:textColor="#94A3B8"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_go_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Log in"
                android:textColor="#1560BD"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>