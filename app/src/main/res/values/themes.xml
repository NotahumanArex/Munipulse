<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MuniPulse" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mp_blue</item>
        <item name="colorPrimaryVariant">@color/mp_blue_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/mp_orange</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_page</item>
        <item name="android:windowBackground">@color/bg_page</item>

        <item name="android:statusBarColor">@color/mp_blue</item>
        <item name="android:navigationBarColor">@color/bg_card</item>

        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="MuniPulse.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/mp_blue</item>
        <item name="titleTextColor">@android:color/white</item>
        <item name="subtitleTextColor">@color/overlay_white_20</item>
    </style>

    <style name="MuniPulse.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:layout_marginTop">10dp</item>
    </style>

    <style name="MuniPulse.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/mp_blue</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="MuniPulse.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/mp_blue</item>
        <item name="android:textColor">@color/mp_blue</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="MuniPulse.Button.Green" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/mp_green_light</item>
        <item name="android:textColor">@color/mp_green</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="MuniPulse.Button.Red" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/mp_red_light</item>
        <item name="android:textColor">@color/mp_red</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="MuniPulse.Button.Blue" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/mp_blue_light</item>
        <item name="android:textColor">@color/mp_blue</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="MuniPulse.Button.Orange" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/mp_orange_light</item>
        <item name="android:textColor">@color/mp_orange</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="MuniPulse.Text.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="MuniPulse.Text.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="MuniPulse.Text.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="MuniPulse.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabBackground">@color/bg_card</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabSelectedTextColor">@color/mp_blue</item>
        <item name="tabIndicatorColor">@color/mp_blue</item>
        <item name="tabIndicatorHeight">2.5dp</item>
        <item name="tabTextAppearance">@style/MuniPulse.TabText</item>
        <item name="tabRippleColor">@color/mp_blue_light</item>
    </style>

    <style name="MuniPulse.TabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">12sp</item>
        <item name="textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="MuniPulse.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_card</item>
        <item name="itemIconTint">@drawable/bottom_nav_color_selector</item>
        <item name="itemTextColor">@drawable/bottom_nav_color_selector</item>
        <item name="itemTextAppearanceActive">@style/MuniPulse.BottomNav.Text</item>
        <item name="itemTextAppearanceInactive">@style/MuniPulse.BottomNav.Text</item>
        <item name="elevation">8dp</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="MuniPulse.BottomNav.Text">
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="MuniPulse.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/bg_page</item>
    </style>
    <style name="Theme.MuniPulse.FullScreen" parent="Theme.MuniPulse">
        <item name="android:windowFullscreen">true</item>
    </style>


</resources>